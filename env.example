# ── HF Group CDC Simulator — Environment Config ───────────────────────────────
# Copy this to .env and edit as needed.
# docker-compose automatically loads .env from the same directory.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=hfgroup
DB_PASSWORD=hfgroup_secret

# ── Simulator scenario ────────────────────────────────────────────────────────
# Options: seed | transactions | updates | journey | burst | backfill | all
SCENARIO=all

# Number of transaction events to generate (used by transactions + burst)
COUNT=200

# Seconds between messages — 1.0 = readable logs, 0.1 = stress test, 0 = burst
INTERVAL=1.0

# Backfill settings — how many days of history to generate
DAYS=3
TXNS_PER_DAY=30

# Journey scenario — leave blank to pick a random seeded customer
CUSTOMER_ID=
